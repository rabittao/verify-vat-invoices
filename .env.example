# Invoice extraction model and API key
# Used by scripts/extract_invoices.py via DashScope compatible API.
QWEN_API_KEY=your_qwen_api_key_here
QWEN_INVOICE_MODEL=qwen3.5-plus

# CAPTCHA OCR model
# Used by scripts/verify_invoices.js via OpenRouter.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the captcha OCR model.
# Default: google/gemini-3-flash-preview
# OPENROUTER_CAPTCHA_MODEL=google/gemini-3-flash-preview

# Optional: use an existing Chrome profile so the tax website can reuse
# local browser trust settings/certificates when needed.
# CHROME_USER_DATA_DIR=/Users/your-name/Library/Application Support/Google/Chrome

# FastAPI application settings
# Required in any persistent environment: API signing key for bearer token generation.
# If omitted, the app will generate a temporary random key at startup and all tokens
# will become invalid after restart.
# API_SECRET_KEY=replace_me_with_a_long_random_secret

# Required before first production-like startup: bootstrap admin account for the local backend.
# APP_ADMIN_USERNAME=admin
# APP_ADMIN_PASSWORD=replace_me_with_a_strong_password

# Optional: force inline job execution (useful for tests only).
# APP_INLINE_JOBS=false
